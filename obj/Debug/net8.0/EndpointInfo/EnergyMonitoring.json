{
  "openapi": "3.0.1",
  "info": {
    "title": "EnergyMonitoring",
    "version": "1.0"
  },
  "paths": {
    "/api/v1/Database/post-pzemraw": {
      "post": {
        "tags": [
          "Database"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PzemRaw"
                }
              }
            },
            "text/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PzemRaw"
                }
              }
            },
            "application/*+json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PzemRaw"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/Database/put-energyminute": {
      "put": {
        "tags": [
          "Database"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EnergyMinute"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EnergyMinute"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EnergyMinute"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/data-visualize/one-day": {
      "get": {
        "tags": [
          "DataVisualizeController1"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/data-visualize/one-day-hourly": {
      "get": {
        "tags": [
          "DataVisualizeController1"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EnergyMinute": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "minute": {
            "type": "string",
            "format": "date-time"
          },
          "energyKwh": {
            "type": "number",
            "format": "float"
          },
          "maxPower": {
            "type": "number",
            "format": "float"
          }
        },
        "additionalProperties": false
      },
      "PzemRaw": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "voltage": {
            "type": "number",
            "format": "float"
          },
          "current": {
            "type": "number",
            "format": "float"
          },
          "power": {
            "type": "number",
            "format": "float"
          },
          "energy": {
            "type": "number",
            "format": "float"
          },
          "frequency": {
            "type": "number",
            "format": "float"
          },
          "powerFactor": {
            "type": "number",
            "format": "float"
          },
          "alarm": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
}